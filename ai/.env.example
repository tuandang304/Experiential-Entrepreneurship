# ============================================================
# AIMA AI SERVICE CONFIGURATION
# ============================================================

# --- LLM provider selection -------------------------------
# Which provider the agents use: "anthropic" (default) or "google".
LLM_PROVIDER=anthropic

# Anthropic (Claude) — used when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google (Gemini) — used when LLM_PROVIDER=google
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.5-pro

# Max tokens per generation (non-streaming default).
LLM_MAX_TOKENS=16000

# --- AI service -------------------------------------------
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000

# ============================================================
# SOCIAL PLATFORM DATA COLLECTION (trend research)
# ============================================================

# Facebook — used by the trend collector. Leave blank to run on mock data.
# Token needs: pages_read_engagement (for pages you manage / public metadata access).
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
FACEBOOK_USER_ACCESS_TOKEN=your_facebook_user_access_token_here

# RapidAPI — MỘT key dùng chung cho mọi API đã subscribe trên tài khoản RapidAPI
# (header x-rapidapi-host chọn API). Trend research dùng:
#   - "tiktok-best-experience" → TikTok trending (toàn cầu / theo region)
#   - "yt-api" (ytjar)         → YouTube trending theo region + search theo từ khóa thương hiệu
# Leave blank to run on mock data. Instagram-Reels source needs no key.
RAPIDAPI_KEY=your_rapidapi_key_here

# (Legacy — vẫn được đọc nếu RAPIDAPI_KEY trống.)
TIKTOK_RAPIDAPI_KEY=your_rapidapi_key_here

# Host API YouTube trên RapidAPI — đổi được sang API khác cùng shape mà không sửa code.
YOUTUBE_RAPIDAPI_HOST=yt-api.p.rapidapi.com

# Host API Instagram trên RapidAPI — lấy bài theo hashtag thương hiệu (GET /v1/hashtag).
INSTAGRAM_RAPIDAPI_HOST=instagram-scraper-api2.p.rapidapi.com

# Threads keyword search — API CHÍNH THỨC của Meta (không qua RapidAPI, miễn phí).
# Dán long-lived user token của một tài khoản Threads đã kết nối; token cần quyền
# threads_keyword_search (thêm scope này vào META_THREADS_SCOPES phía backend khi connect).
THREADS_ACCESS_TOKEN=your_threads_access_token_here
THREADS_API_BASE=https://graph.threads.net/v1.0

# Region mặc định cho trending/search (ISO 3166, vd VN) khi request không chỉ định.
TRENDS_DEFAULT_REGION=VN
