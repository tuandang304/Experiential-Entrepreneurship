# Supabase Storage (service_role key is BACKEND ONLY — never expose to the frontend)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# AES-256 encryption key for access token storage (32 bytes base64: openssl rand -base64 32)
AIMA_ENCRYPTION_KEY=

# AI service (Python/FastAPI) — content generation
AI_SERVICE_BASE_URL=
AI_SERVICE_TIMEOUT_SECONDS=


AI_SERVICE_BASE_URL=
AI_SERVICE_TIMEOUT_SECONDS=
# AI config theo DB (trang admin "Cấu hình AI"). Mặc định false = giữ hành vi env cũ.
AI_CONFIG_FROM_DB=
# Shared secret backend↔AI service (openssl rand -base64 32) — CÙNG giá trị AI_INTERNAL_TOKEN ở ai/.env
AI_INTERNAL_TOKEN=
# Seed key/model 1 lần từ env (tuỳ chọn — copy từ ai/.env; trống thì admin dán key qua UI)
AI_SEED_ANTHROPIC_API_KEY=
AI_SEED_ANTHROPIC_MODEL=
AI_SEED_GOOGLE_API_KEY=
AI_SEED_GOOGLE_MODEL=

# Meta Social Platform Connections (Facebook / Instagram / Threads)
META_FACEBOOK_APP_ID=
META_FACEBOOK_APP_SECRET=
META_FACEBOOK_REDIRECT_URI=
META_THREADS_APP_ID=
META_THREADS_APP_SECRET=
META_THREADS_REDIRECT_URI=
META_APP_SECRET_PROOF_ENABLED=
FE_OAUTH_SUCCESS_URL=
FE_OAUTH_ERROR_URL=

# Auth cookie (HttpOnly access_token + refresh_token)
# COOKIE_DOMAIN: de trong = khong set Domain (local dev). Khi FE/BE cung domain goc:
#   .aima-marketing.id.vn  -> cookie thanh first-party, Safari/Brave khong chan
COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=
AUTH_COOKIE_SAME_SITE=
AUTH_COOKIE_PATH=
