VITE_API_BASE_URL=

# Trang Phân tích (UI-08) TỰ hiển thị dữ liệu mẫu khi chưa có số liệu thật / API lỗi (kèm badge
# "Dữ liệu mẫu") — không cần cấu hình gì. Đặt VITE_USE_MOCK=true để ÉP dùng mock kể cả khi có số
# liệu thật (chụp ảnh giao diện đầy đủ). Production để trống/false. Đổi .env phải restart dev server.
VITE_USE_MOCK=false
