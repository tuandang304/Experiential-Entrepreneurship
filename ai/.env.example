# CONFIGURATION FOR ACTUAL SOCIAL PLATFORM POSTING

# 1. FACEBOOK CREDENTIALS
# Lấy Page ID từ mục Giới thiệu (About) của Fanpage
FACEBOOK_PAGE_ID=your_facebook_page_id_here

# Lấy Page Access Token từ Facebook Developer Portal (Graph API Explorer)
# Token này cần có quyền: pages_manage_posts, pages_read_engagement
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here

# 2. TIKTOK CREDENTIALS (IF APPLICABLE)
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# 3. INSTAGRAM CREDENTIALS (IF APPLICABLE)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
